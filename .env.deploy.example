# 复制为 .env.deploy 后填写；不要把 .env.deploy 提交到 Git。

# Kaggle API Token。没有它时，分数读取和源码归档会不可用。
KAGGLE_API_TOKEN=
KAGGLE_COMPETITION=rogii-wellbore-geology-prediction

# 容器只监听本机，由 Caddy 或 Cloudflare Tunnel 提供 HTTPS 公网入口。
# 如果暂时不使用反向代理，改为 APP_BIND_ADDRESS=0.0.0.0、APP_PORT=80。
APP_BIND_ADDRESS=127.0.0.1
APP_PORT=8080

# Linux 容器重启后仍需保留通知密钥，因此建议通过环境变量注入。
# Webhook 地址必须为 HTTPS（本机地址除外）。
HARVESTER_NOTIFICATION_WEBHOOK_URL=
# SMTP 授权码或应用专用密码，不是邮箱登录密码。
HARVESTER_NOTIFICATION_SMTP_PASSWORD=
